  "description": "PocketPilot AI Finance Backend — Production-grade SaaS backend",
  "main": "dist/server.js",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "npx prisma generate",
