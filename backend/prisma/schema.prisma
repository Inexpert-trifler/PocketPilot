// prisma/schema.prisma
// Complete database schema for PocketPilot SaaS backend.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TransactionCategory {
  FOOD
  SHOPPING
  GAMING
  SUBSCRIPTIONS
  EDUCATION
  TRAVEL
  ENTERTAINMENT
  RENT
  BILLS
  HEALTHCARE
  TRANSPORT
  SALARY
  FREELANCE
  TRANSFER
  OTHER
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UploadType {
  PDF
  CSV
  IMAGE
  RECEIPT
}

enum InsightType {
  SPENDING_ALERT
  SAVINGS_TIP
  SUBSCRIPTION_ALERT
  BUDGET_WARNING
  BEHAVIORAL_PATTERN
  ACHIEVEMENT
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum NotificationType {
  BUDGET_ALERT
  GOAL_MILESTONE
  WEEKLY_SUMMARY
  SUBSCRIPTION_DETECTED
  OVERSPENDING_WARNING
  INSIGHT_READY
}

// ────────────────────────────────────────────────────────────────
// USER
// ────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  avatarUrl       String?
  passwordHash    String
  role            Role     @default(USER)
  isEmailVerified Boolean  @default(false)
  onboardingDone  Boolean  @default(false)
  monthlyBudget   Float?
  currency        String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  sessions      Session[]
  uploads       Upload[]
  transactions  Transaction[]
  budgets       Budget[]
  goals         SavingsGoal[]
  subscriptions Subscription[]
  insights      Insight[]
  notifications Notification[]

  @@index([email])
}

// ────────────────────────────────────────────────────────────────
// AUTH SESSION
// ────────────────────────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

// ────────────────────────────────────────────────────────────────
// FILE UPLOAD
// ────────────────────────────────────────────────────────────────

model Upload {
  id           String       @id @default(cuid())
  userId       String
  originalName String
  mimeType     String
  sizeBytes    Int
  storageUrl   String
  storageKey   String
  type         UploadType
  status       UploadStatus @default(PENDING)
  errorMessage String?
  jobId        String?      // BullMQ job ID
  metadata     Json?        // OCR results, page count, etc.
  processedAt  DateTime?
  createdAt    DateTime     @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────────
// TRANSACTION
// ────────────────────────────────────────────────────────────────

model Transaction {
  id              String              @id @default(cuid())
  userId          String
  uploadId        String?
  amount          Float
  type            TransactionType
  category        TransactionCategory @default(OTHER)
  merchantName    String?
  merchantRaw     String?             // Original merchant string from OCR
  description     String?
  date            DateTime
  currency        String              @default("INR")
  isRecurring     Boolean             @default(false)
  recurringId     String?             // Link to Subscription
  isCategorizedAI Boolean             @default(false)
  confidence      Float?              // AI categorization confidence 0-1
  tags            String[]            @default([])
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  upload       Upload?       @relation(fields: [uploadId], references: [id])
  subscription Subscription? @relation(fields: [recurringId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, isRecurring])
}

// ────────────────────────────────────────────────────────────────
// BUDGET
// ────────────────────────────────────────────────────────────────

model Budget {
  id        String              @id @default(cuid())
  userId    String
  category  TransactionCategory
  amount    Float
  spent     Float               @default(0)
  month     Int                 // 1-12
  year      Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
  @@index([userId, year, month])
}

// ────────────────────────────────────────────────────────────────
// SAVINGS GOAL
// ────────────────────────────────────────────────────────────────

model SavingsGoal {
  id            String     @id @default(cuid())
  userId        String
  name          String
  emoji         String?
  targetAmount  Float
  currentAmount Float      @default(0)
  targetDate    DateTime?
  status        GoalStatus @default(ACTIVE)
  autoSaveAmount Float?    // AI-recommended monthly contribution
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

// ────────────────────────────────────────────────────────────────
// SUBSCRIPTION
// ────────────────────────────────────────────────────────────────

model Subscription {
  id             String   @id @default(cuid())
  userId         String
  name           String
  merchantName   String
  amount         Float
  currency       String   @default("INR")
  intervalDays   Int      // 30, 7, 365, etc.
  lastChargedAt  DateTime?
  nextChargedAt  DateTime?
  isActive       Boolean  @default(true)
  isUserVerified Boolean  @default(false) // User confirmed this is a subscription
  category       TransactionCategory @default(SUBSCRIPTIONS)
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([userId, isActive])
}

// ────────────────────────────────────────────────────────────────
// AI INSIGHT
// ────────────────────────────────────────────────────────────────

model Insight {
  id        String          @id @default(cuid())
  userId    String
  type      InsightType
  priority  InsightPriority @default(MEDIUM)
  title     String
  body      String
  actionUrl String?         // Deep link for action
  isRead    Boolean         @default(false)
  isDismissed Boolean       @default(false)
  metadata  Json?           // Raw data that triggered this insight
  expiresAt DateTime?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, type])
}

// ────────────────────────────────────────────────────────────────
// NOTIFICATION
// ────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}
